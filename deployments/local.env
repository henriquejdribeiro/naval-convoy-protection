# =============================================================================
# Live deployment addresses on the local Geth Clique-PoA chain.
#
# Deterministic from anvil[0] deployer + sequential nonces under the
# DeployL1.s.sol contract order (post-Verifier-rewrite, no more relay
# arg + no STARK_VERIFIER_ADDR):
#   nonce 0  →  StarknetCoreStub
#   nonce 1  →  Registry
#   nonce 2  →  Verifier
#   nonce 3  →  CommandLog
#   nonce 4  →  Registry.setVerifier (no new contract)
#
# These values are stable across re-deploys on a clean chain.
# =============================================================================

# ── Chain ────────────────────────────────────────────────────────────────────
export URL=http://localhost:18545
export CHAIN_ID=11155111

