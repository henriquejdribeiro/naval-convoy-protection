# Environment
.env
.env.local

# Node / npm (in case docs tooling is added later)
node_modules/
package-lock.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Claude Code local state (per-machine, never commit)
.claude/

# Build / cache
dist/
build/
.cache/

# Docker / persistent volumes (Phase 2+)
infrastructure/**/data/
infrastructure/**/keystore/

# Generated proofs / artifacts (Phase 3+)
proofs/
artifacts/
*.pie
*.proof.json

# Geth keystores — regenerated deterministically by scripts/generate-keys.sh
# from the well-known anvil mnemonic. Not committed (no value to track).
infrastructure/geth/keys/*.json

# Foundry build artifacts (the contracts/.gitignore covers this too;
# duplicated at repo root in case forge is run from elsewhere)
contracts/out/
contracts/cache/
contracts/broadcast/
# Forge auto-installed deps — gitignored per-subdir so the
# starkex-contracts submodule isn't blanket-blocked by a parent rule
# (git ignores parent-dir excludes even with `!` re-include).
contracts/lib/openzeppelin-contracts/
contracts/lib/forge-std/

# Temp dir used during keystore generation
.tmp-keys/

# Phase 3.b L2 deployment artefacts (regenerated by scripts/deploy-l2.sh —
# contains an encrypted keystore with a hard-coded dev password, plus the
# auto-derived account.json and contract addresses. Don't commit.)
.tmp-l2/

# Scarb / Cairo 1 build outputs (regenerated by scarb build)
cairo/**/target/
cairo/**/Scarb.lock

# Demo recordings (regenerated by scripts/record-sim.py)
out/

# Stray copy of the orchestrator binary used for one-shot strings(1)
# inspection (yesterday's `cp /usr/bin/orchestrator ./_orch`)
_orch
infrastructure/path-a-runner/target/
infrastructure/path-a-runner/Cargo.lock
infrastructure/bootloader-cli/target/
infrastructure/submitter/target/
