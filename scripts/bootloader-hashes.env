# =============================================================================
# Bootloader constants for DeployStarkVerifier.s.sol
#
# Source these before invoking `forge script DeployStarkVerifier`:
#
#     source scripts/bootloader-hashes.env
#     forge script script/DeployStarkVerifier.s.sol:DeployStarkVerifier \
#         --rpc-url http://localhost:18545 --broadcast
#
# What these are
# --------------
#
#   SIMPLE_BOOTLOADER_HASH    The Cairo program hash of the simple
#                             bootloader bytecode embedded in
#                             contracts/lib/starkex-contracts/
#                             evm-verifier/solidity/contracts/cpu/
#                             CairoBootloaderProgram.sol
#                             (PROGRAM_SIZE = 566 felts).
#
#                             The value below is the on-chain hash
#                             published by zksecurity as the canonical
#                             simple-bootloader hash used by StarkWare's
#                             mainnet GpsStatementVerifier deployments.
#                             Source:
#                             vendor/stark-evm-adapter/examples/bootloader/
#                                 test_bootloader_fib.py
#                             where it is labelled `# on-chain hash`.
#
#                             To re-derive it independently, run the
#                             scripts/compute-bootloader-hashes.py
#                             helper in an environment that ships the
#                             compiled simple_bootloader JSON (older
#                             cairo-lang versions used to bundle it
#                             under starkware/cairo/bootloaders/simple_bootloader/;
#                             newer ones do not).
#
#   HASHED_CAIRO_VERIFIERS    Pedersen-hash chain over the list of
#                             Cairo verifier program hashes the
#                             bootloader is permitted to invoke
#                             recursively. For a non-recursive
#                             deployment (the convoy protocol uses no
#                             recursive STARK aggregation), the list
#                             is empty and the value is 0.
#
# Without correct values for these, GpsStatementVerifier reverts at
# registerPublicMemoryMainPage with "Invalid hash for memory page 0",
# because the bootloader output committed to in the public memory will
# not match what the contract expects.
# =============================================================================

# v0.13.0 bootloader hash — recomputed locally with cairo-lang's
# compute_program_hash_chain against vendor/cairo-bootloader/resources/
# bootloader-0.13.0.json (the same bytecode now embedded in the
# regenerated CairoBootloaderProgram.sol by
# scripts/regenerate-cairo-bootloader-program.py).
#
# The previous value (0xd875840a…) was for the older 566-felt simple
# bootloader shipped by starkex-contracts StarkPerpetual-v3.2; that
# version is no longer in the on-chain contract.
export SIMPLE_BOOTLOADER_HASH=0x3106b7628a3cbddadb733ea96284977cc21e890d61aa6dee00badcbd90065ce
export HASHED_CAIRO_VERIFIERS=0x0
