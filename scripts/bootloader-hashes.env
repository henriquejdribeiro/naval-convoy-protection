# =============================================================================
# Bootloader constants for DeployStarkVerifier.s.sol
#
# Source these before invoking `forge script DeployStarkVerifier`:
#
#     source scripts/bootloader-hashes.env
#     forge script script/DeployStarkVerifier.s.sol:DeployStarkVerifier \
#         --rpc-url http://localhost:18545 --broadcast
#
# What these are
# --------------
#
#   SIMPLE_BOOTLOADER_HASH    The Cairo program hash of the simple
#                             bootloader bytecode embedded in
#                             contracts/lib/starkware-mainnet/
#                             starkware/solidity/verifier/cpu/
#                             CairoBootloaderProgram.sol -- regenerated
#                             from vendor/cairo-bootloader/resources/
#                             bootloader-0.13.0.json (the canonical 8-
#                             builtin bootloader Moonsong-Labs's
#                             cairo-bootloader library bundles).
#
#                             PROGRAM_SIZE = 718 felts.
#
#                             To re-derive it independently, run inside
#                             the convoy-prover-api container:
#
#                               python3 -c "
#                                 import json
#                                 from starkware.cairo.bootloaders.hash_program \
#                                     import compute_program_hash_chain, HashFunction
#                                 from starkware.cairo.lang.compiler.program import Program
#                                 p = Program.Schema().load(json.load(
#                                     open('/work/vendor/cairo-bootloader/resources/bootloader-0.13.0.json')))
#                                 print(hex(compute_program_hash_chain(
#                                     program=p, program_hash_function=HashFunction.PEDERSEN)))
#                               "
#
#   HASHED_CAIRO_VERIFIERS    Pedersen-hash chain over the list of
#                             Cairo verifier program hashes the
#                             bootloader is permitted to invoke
#                             recursively. For a non-recursive deployment
#                             (the convoy protocol uses no recursive STARK
#                             aggregation), the list is empty and the
#                             value is `hash_felts([])` -- which equals
#                             pedersen_hash(0, 0) = the Pedersen shift
#                             point X coordinate.
#
# Without correct values for these, GpsStatementVerifier reverts at
# registerPublicMemoryMainPage with "Invalid hash for memory page 0",
# because the bootloader output committed to in the public memory will
# not match what the contract expects.
# =============================================================================

# Canonical 8-builtin bootloader hash (layout 6 = starknet, builtins:
# output, pedersen, range_check, ecdsa, bitwise, ec_op, keccak, poseidon).
# Computed by compute_program_hash_chain(program, HashFunction.PEDERSEN)
# against vendor/cairo-bootloader/resources/bootloader-0.13.0.json
# AS-IS (no keccak stripping, no convoy modifications).
# Bootloader data length: 718 felts.
export SIMPLE_BOOTLOADER_HASH=0x03106b7628a3cbddadb733ea96284977cc21e890d61aa6dee00badcbd90065ce

# hash_felts([]) = pedersen(0, 0) = Pedersen shift point X.
export HASHED_CAIRO_VERIFIERS=0x049ee3eba8c1600700ee1b87eb599f16716b0b1022947733551fde4050ca6804
